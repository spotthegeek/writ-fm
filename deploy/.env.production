# WRIT-FM Production Environment
# Place this file on the Swarm manager at /opt/writ-fm/.env.production
# Source before deploying: set -a && source .env.production && set +a

VERSION=latest

# ── Kokoro TTS (GPU host) ───────────────────────────────────────────────────
KOKORO_SERVICE_URL=http://kokoro.area4.net:8880

# ── LLM (Ollama) ────────────────────────────────────────────────────────────
OLLAMA_URL=http://ollama.area4.net:11434
OLLAMA_MODEL=llama3.2:3b

# ── TTS APIs ────────────────────────────────────────────────────────────────
GOOGLE_TTS_MODEL=gemini-3.1-flash-tts-preview
GEMINI_API_KEY=
GOOGLE_TTS_API_KEY=
MINIMAX_API_KEY=
MINIMAX_TOKEN_PLAN_API_KEY=
MINIMAX_MUSIC_MODEL=music-2.6

# ── Icecast ──────────────────────────────────────────────────────────────────
# ICECAST_HOST defaults to 'icecast' (the stack service name) — only set if external
# ICECAST_HOST=icecast
ICECAST_PORT=8000
ICECAST_PASS=
ICECAST_ADMIN_PASS=
ICECAST_HOSTNAME=radio.area4.net   # public hostname shown in Icecast UI / playlist URLs

# ── Admin ────────────────────────────────────────────────────────────────────
WRIT_ADMIN_PORT=8080
WRIT_ADMIN_PASSWORD=

# ── Listener app ─────────────────────────────────────────────────────────────
WRIT_LISTENER_AUTH=1
WRIT_LISTENER_LAN_RANGES=10.0.0.0/23

# ── Audiobookshelf ───────────────────────────────────────────────────────────
WRIT_ABS_URL=https://abs.area4.net
WRIT_ABS_API_KEY=
WRIT_INGEST_API_KEY=

# ── Misc ─────────────────────────────────────────────────────────────────────
HF_TOKEN=
